# Supabase default Edge Function variables
# These are available automatically in hosted Supabase Edge Functions.
# Do NOT add variables starting with SUPABASE_ in the dashboard Secrets page.
# For local development only, you may place these in a local .env file.
# SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
# SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
# SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# Meta / Facebook
FACEBOOK_APP_ID=YOUR_FACEBOOK_APP_ID
FACEBOOK_APP_SECRET=YOUR_FACEBOOK_APP_SECRET
FACEBOOK_REDIRECT_URI=https://YOUR_PROJECT_ID.supabase.co/functions/v1/facebook-oauth/callback
FACEBOOK_GRAPH_VERSION=v20.0

# Admin review API
ADMIN_API_KEY=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET
